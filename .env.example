# Parking ANPR — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your_service_role_key_here     # use service-role for server writes

# ── Camera sources (override config.py defaults) ─────────────────────────────
# 0, 1, 2 = webcam index; or RTSP/HTTP URL
# ENTRY_CAMERA=0
# EXIT_CAMERA=1

# ── Optional: Supabase Storage bucket for plate snapshots ────────────────────
# STORAGE_BUCKET_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/plates
